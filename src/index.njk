<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ resume.name }} — CV / Resume</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="/css/main.css"">
</head>
<body>

    <!-- ════════════════════════════════════════════════════ -->
    <!--  HEADER                                               -->
    <!-- ════════════════════════════════════════════════════ -->
    <header>
        <div class="container">
            <h1>{{ resume.name }}</h1>
            <p class="title-role">{{ resume.role }}</p>
            <div class="header-links">
                {% for link in resume.links %}
                {% if link.label == "LinkedIn" %}
                <a href="{{ link.url }}" target="_blank" rel="noopener">
                    <!-- LinkedIn icon -->
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                        <rect x="2" y="9" width="4" height="12" />
                        <circle cx="4" cy="4" r="2" />
                    </svg>
                    {{ link.label }}
                </a>
                {% elif link.label == "GitHub" %}
                <a href="{{ link.url }}" target="_blank" rel="noopener">
                    <!-- GitHub icon -->
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                        <path d="M9 18c-4.51 2-5-2-7-2" />
                    </svg>
                    {{ link.label }}
                </a>
                {% elif link.label == "Email" %}
                <a href="{{ link.url }}">
                    <!-- Mail icon -->
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="4" width="20" height="16" rx="2" />
                        <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                    </svg>
                    {{ resume.email }}
                </a>
                {% endif %}
                {% endfor %}
                <span>
                    <!-- Location icon -->
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:middle;margin-right:4px;">
                        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
                        <circle cx="12" cy="10" r="3" />
                    </svg>
                    {{ resume.location }}
                </span>
            </div>
        </div>
    </header>

    <main>

        <!-- ════════════════════════════════════════════════════ -->
        <!--  ABOUT                                                -->
        <!-- ════════════════════════════════════════════════════ -->
        <section id="about">
            <div class="container">
                <p class="section-label">About</p>
                <p>{{ resume.about }}</p>
            </div>
        </section>

        <!-- ════════════════════════════════════════════════════ -->
        <!--  EXPERIENCE                                           -->
        <!-- ════════════════════════════════════════════════════ -->
        <section id="experience">
            <div class="container">
                <p class="section-label">Experience</p>

                {% for item in resume.experience %}
                <div class="experience-item">
                    <div class="exp-header">
                        <span class="exp-company">{{ item.company }}</span>
                        <span class="exp-date">{{ item.date }}</span>
                    </div>
                    <div class="exp-title">{{ item.title }}</div>
                    <div class="exp-location">{{ item.location }}</div>
                    <div class="exp-description">
                        {{ item.description }}
                        {% if item.highlights %}
                        <ul>
                            {% for highlight in item.highlights %}
                            <li>{{ highlight }}</li>
                            {% endfor %}
                        </ul>
                        {% endif %}
                        {% if item.skills %}
                        <div class="skill-tags">
                            {% for skill in item.skills %}
                            <span class="skill-tag">{{ skill }}</span>
                            {% endfor %}
                        </div>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}

            </div>
        </section>

        <!-- ════════════════════════════════════════════════════ -->
        <!--  PROJECTS                                             -->
        <!-- ════════════════════════════════════════════════════ -->
        <section id="projects">
            <div class="container">
                <p class="section-label">Projects</p>
                <div class="projects-grid">

                    {% for project in resume.projects %}
                    {% if project.url %}
                    <a class="project-card" href="{{ project.url }}">
                    {% else %}
                    <div class="project-card">
                    {% endif %}
                        <div class="project-logo">
                            {% if project.logo is defined %}
                                <img src="{{ project.logo }}" alt="{{ project.name }} Logo" />
                            {% else %}
                                ⌘
                            {% endif %}
                        </div>
                        <div class="project-name">{{ project.name }}</div>
                        <div class="project-description">{{ project.description }}</div>
                        <div class="project-tags">
                            {% for tag in project.tags %}
                            <span class="project-tag">{{ tag }}</span>
                            {% endfor %}
                        </div>
                    {% if project.url %}
                    </a>
                    {% else %}
                    </div>
                    {% endif %}
                    {% endfor %}

                </div>
            </div>
        </section>

        <!-- ════════════════════════════════════════════════════ -->
        <!--  EDUCATION                                            -->
        <!-- ════════════════════════════════════════════════════ -->
        <section id="education">
            <div class="container">
                <p class="section-label">Education</p>

                {% for item in resume.education %}
                <div class="education-item">
                    <div class="edu-left">
                        <div class="edu-school">{{ item.school }}</div>
                        <div class="edu-degree">{{ item.degree }}</div>
                        {% if item.note %}
                        <div class="edu-note">{{ item.note }}</div>
                        {% endif %}
                    </div>
                    <div class="edu-date">{{ item.date }}</div>
                </div>
                {% endfor %}

            </div>
        </section>

    </main>

    <!-- ════════════════════════════════════════════════════ -->
    <!--  FOOTER                                               -->
    <!-- ════════════════════════════════════════════════════ -->
    <footer>
        <div class="container">
            <p>© {{ resume.year }} <a href="{{ resume.website }}">{{ resume.name }}</a></p>
        </div>
    </footer>

</body>
</html>
